{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "paths": {
            "@repo/*": ["../../packages/*"],
            "@/*": ["./*"]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts",
        "**/*.mts"
    ],
    "exclude": ["node_modules"]
}
